# ============================================================================
# Configuration contract — every variable the stack reads
# Copy to `.env` and fill the LLM keys. Never commit `.env`.
# Safe defaults below work for the compose stack out of the box.
# ============================================================================

# --- Runtime -----------------------------------------------------------------
# local | test | demo | prod — toggles docs exposure, log level, seed permission
ENV=local
LOG_LEVEL=INFO

# --- Infrastructure ----------------------------------------------------------
# In-compose hostnames; for host-side dev use localhost + published ports.
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app
CHROMA_URL=http://chromadb:8000
# Chroma rejects names shorter than 3 chars ([a-zA-Z0-9._-], alnum at both ends).
CHROMA_COLLECTION=knowledge_base
MCP_SERVER_URL=http://mcp-server:8080/mcp
# Used only by the MCP process to own the simulated banking read model.
MCP_DATABASE_URL=postgresql://app:app@postgres:5432/app

# Compose-only: postgres container bootstrap (must agree with DATABASE_URL)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- LLM providers (ADR-008) — keys have NO safe default ----------------------
# Gemini is the normal demo provider. `python main.py` can provision a native
# Ollama installation on the host and switch chat + embeddings to it; Ollama is
# not run in Docker Compose.
LLM_PROVIDER=gemini
LLM_FALLBACK_ORDER=gemini,openrouter,ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_PROVIDER=gemini
# gemini-embedding-001 emits 3072 dims by default; 768 (a supported MRL size) keeps
# parity with nomic-embed-text so the providers stay swappable in one collection.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Managed by main.py after a successful forced KB ingestion. Leave blank when
# changing embedding providers/models so the launcher reindexes the collection.
KB_INDEX_EMBEDDING=

# --- RAG retrieval (rag.md §3) -------------------------------------------------
# RAG_RELEVANCE_FLOOR is the primary hallucination control: below it the agent
# refuses instead of answering (BR-8.3). 0.66 was calibrated on the golden set
# (eval-report.md) for gemini-embedding-001@768: midway between the answerable
# minimum (0.724) and the unanswerable maximum (0.595). It is model-specific —
# re-run `make eval-rag` after any embedding-model or corpus change.
RAG_TOP_K=6
RAG_RELEVANCE_FLOOR=0.66
RAG_CONTEXT_TOKEN_CAP=2000
RAG_DEDUPE_SIMILARITY=0.97

# --- Agent ----------------------------------------------------------------------
# History is kept verbatim (no summarization); the token budget assumes the smallest
# context in the fallback chain, so these caps are limits, not hints.
AGENT_HISTORY_WINDOW_TURNS=20
AGENT_MAX_INPUT_CHARS=4000
AGENT_ANSWER_MAX_TOKENS=512
AGENT_GENERATION_TEMPERATURE=0.3
# O2 grounding judge: one extra LLM call per KB answer. Turning it off trades a
# hallucination control for latency/quota — a deliberate choice, never a default drift.
AGENT_GROUNDING_JUDGE_ENABLED=true

# --- Observability (Langfuse) ---------------------------------------------------
# The compose stack provisions this project + these keys at boot (headless init),
# so `make up` gives you a traced stack with no click-through. Demo values, local
# only — like JWT_SECRET below, change them for any shared environment.
# Both keys empty ⇒ the no-op tracer: the app still runs and says so once at boot.
# That is the supported way to run tests/evals, not a degraded mode. No key has a
# default in code — a secret with a default in code is a secret in git.
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=lf_pk_itau_agent_demo_000000000001
LANGFUSE_SECRET_KEY=lf_sk_itau_agent_demo_000000000001
LANGFUSE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Compose-only: langfuse's own database + server secrets + the seeded UI login
# (http://localhost:3001) — demo values.
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_DB_NAME=langfuse
LANGFUSE_NEXTAUTH_SECRET=dev-nextauth-secret-change-me
LANGFUSE_SALT=dev-salt-change-me
LANGFUSE_INIT_USER_EMAIL=admin@demo.local
LANGFUSE_INIT_USER_PASSWORD=langfuse123

# --- Auth ---------------------------------------------------------------------
# Demo HS256 secret — required, no default in code; change for any shared env.
JWT_SECRET=dev-jwt-secret-change-me
JWT_TTL_MINUTES=60
# Seed-only: password for the demo personas (ana/bruno/carla@demo)
SEED_PASSWORD=demo123

# --- Operation gates (business rules, env-tunable for evaluation) --------------
STEP_UP_TTL_MINUTES=5
CONFIRMATION_TTL_MINUTES=5
PIX_DAILY_LIMIT=5000
PIX_STEPUP_THRESHOLD=1000
# Card-limit maximums per segment as JSON: [score>=800, >=600, <600].
# Uncomment to override the defaults below.
# CARD_LIMIT_MAXIMUMS={"Personnalité": ["50000", "25000", "10000"], "Uniclass": ["30000", "15000", "8000"], "Varejo": ["15000", "8000", "4000"]}

# --- Event delivery (transactional outbox) --------------------------------------
OUTBOX_RELAY_INTERVAL_SECONDS=1
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_MAX_BACKOFF_SECONDS=60

# --- Perimeter ------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30
